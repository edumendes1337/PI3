{
  "version": 2,
  "builds": [
    {
      "src": "front-main/package.json",
      "use": "@vercel/static-builds",
      "config": {
        "distDir": "dist"
      }
    },
    {
      "src": "back-main/src/index.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "back-main/src/index.ts"
    },
    {
      "src": "/(.*)",
      "dest": "front-main/dist/index.html",
      "status": 200
    }
  ]
}
